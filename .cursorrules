## Next.js App Router Patterns

### Server Component (default — for data fetching)
```typescript
import { createServerClient } from '@supabase/ssr'
import { cookies } from 'next/headers'

export default async function TeamPage({ params }: { params: { teamId: string } }) {
  const cookieStore = cookies()
  const supabase = createServerClient(
    process.env.NEXT_PUBLIC_SUPABASE_URL!,
    process.env.NEXT_PUBLIC_SUPABASE_ANON_KEY!,
    { cookies: { get: cookieStore.get.bind(cookieStore) } }
  )

  const { data: files } = await supabase
    .from('markdown_files')
    .select('*')
    .eq('team_id', params.teamId)

  return <TeamFeed files={files ?? []} />
}
```

### Client Component (only when interactive)
Used for: composer Write/Preview toggle, rating widget, share dialogs,
optimistic UI.

### Server Action (for mutations / form submits)
```typescript
'use server'
import { z } from 'zod'

const ShareMDSchema = z.object({
  team_id: z.string().uuid(),
  title:   z.string().min(1).max(200),
  readme:  z.string().max(2000).optional(),
  content: z.string().min(1),
  tags:    z.array(z.enum(['skill','rule','prompt','sop','other']))
})

export async function shareMD(formData: FormData) {
  const parsed = ShareMDSchema.parse(Object.fromEntries(formData))
  // ... insert, RLS enforces team membership and authorship
}
```

