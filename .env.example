# SkillsHub Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

# ── Supabase ──────────────────────────────────────────────────
# Found in: Supabase dashboard → Project Settings → API

# Safe to use client-side (RLS protects your data)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# SERVER ONLY — never use this in client components or expose publicly.
# Bypasses RLS — only use for trusted server-side admin operations.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3111
